# BasicRandomFlow

main: kit: flow: BasicRandomFlow:
{
  entity: "random",
  kind: "basic",
  name: "BasicRandomFlow",
  step: [
    {
      input: {
        ref: "random_ref01",
        srcdatavar: "random_ref01_data",
        suffix: "_dt0"
      }

      match: {
        id: "random01"
      }

      op: "load",
      valid: [
        {
          apply: "TextFieldMark",
          def: {
            mark: "Mark01-random_ref01"
          }
        }
      ]
    }
  ],
  "key$": "BasicRandomFlow"
}